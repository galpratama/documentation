{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "BelajarKoding Docs",
  "description": "Portal dokumentasi produk BelajarKoding. Saat ini tersedia dokumentasi lengkap untuk KilatKoding.",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
