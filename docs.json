    "eyebrows": "breadcrumbs"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Portal",
          "href": "/",
          "icon": "house"
        }
      ]
    },
    "products": [
      {
        "product": "KilatKoding",
        "icon": "bolt",
        "description": "Boilerplate Next.js untuk developer Indonesia dengan auth, pembayaran, email, blog, AI, dan dashboard yang siap pakai.",
        "groups": [
          {
            "group": "Mulai di sini",
            "pages": [
              "kilatkoding/index",
              "kilatkoding/product-overview",
              "kilatkoding/getting-started",
              "kilatkoding/local-setup"
            ]
          },
          {
            "group": "Setup dan integrasi",
            "pages": [
              "kilatkoding/services-setup",
              "kilatkoding/environment-variables"
            ]
          },
          {
            "group": "Fitur dan konfigurasi",
            "pages": [
              "kilatkoding/features-and-routes",
              "kilatkoding/customization",
              "kilatkoding/components-and-ui",
              "kilatkoding/ai-and-tooling"
            ]
          },
          {
            "group": "Teknis",
            "pages": [
              "kilatkoding/architecture",
              "kilatkoding/database-and-storage"
            ]
          },
          {
            "group": "Operasional",
            "pages": [
              "kilatkoding/testing-and-deployment",
              "kilatkoding/troubleshooting"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "/"
  },
  "navbar": {
    "links": [
      {
        "label": "Portal",
        "href": "/"
      }
    ],
    "primary": {
      "type": "github",
      "href": "https://github.com/galpratama/kilatkoding-src"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
